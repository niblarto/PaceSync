# Spotify — https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=https://your-domain.com

# Cron endpoint protection — generate with: openssl rand -hex 24
CRON_SECRET=your_cron_secret

# Runna calendar feed URL (from Runna app → Calendar → Copy ICS link)
RUNNA_ICS_URL=https://cal.runna.com/your_calendar_id.ics

# Your Spotify "Running" playlist ID (from the playlist URL on open.spotify.com)
NEXT_PUBLIC_RUNNING_PLAYLIST_ID=your_spotify_playlist_id

# ntfy.sh topic for push notifications (optional — can also be set in Settings)
NTFY_TOPIC=your_ntfy_topic

# Last.fm API key for song suggestions (optional — https://www.last.fm/api/account/create)
# Without it, suggestion discovery falls back to Deezer related artists (fewer results).
LASTFM_API_KEY=your_lastfm_api_key

# GarminDB sync wrapper paths (optional — only needed for the Settings sync-status card)
# Defaults assume GarminDB installed under the app's own user; override if yours differs.
GARMINDB_SYNC_WRAPPER=/home/pi/garmin_run.py
GARMINDB_PYTHON_BIN=/home/pi/garmindb-venv/bin/python3
GARMINDB_LOG_PATH=/home/pi/garmindb_update.log
